{
  "version": 2,
  "builds": [
    {
      "src": "apps/api/src/index.ts",
      "use": "@vercel/node"
    },
    {
      "src": "apps/web/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "apps/api/src/index.ts"
    },
    {
      "src": "/health",
      "dest": "apps/api/src/index.ts"
    },
    {
      "src": "/assets/(.*)",
      "dest": "apps/web/assets/$1"
    },
    {
      "src": "/favicon.svg",
      "dest": "apps/web/favicon.svg"
    },
    {
      "src": "/(.*\\.(js|css|png|jpg|jpeg|gif|ico|svg|json|woff|woff2))",
      "dest": "apps/web/$1"
    },
    {
      "src": "/(.*)",
      "dest": "apps/web/index.html"
    }
  ]
}
